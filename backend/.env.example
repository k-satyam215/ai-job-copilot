# ════════════════════════════════════════════════════════════════
# AI Job Copilot — Environment Variables Reference
# Copy this file to backend/.env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────
APP_NAME=AI Job Copilot
APP_ENV=development          # development | staging | production
JWT_SECRET=CHANGE_ME_generate_with_python_secrets_token_urlsafe_64
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ─────────────────────────────────────────────────────
# Neon Postgres (recommended for production):
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# Local SQLite (dev only):
# DATABASE_URL=sqlite:///./ai_job_copilot.db

# ── AI / LLM ─────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── SMTP (Email) ─────────────────────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password

# ── Telegram Notifications ───────────────────────────────────────
# Create bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Razorpay Billing ─────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Stripe Billing (optional) ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# ── Frontend / CORS ──────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Observability (optional) ─────────────────────────────────────
# Get from: https://sentry.io
# SENTRY_DSN=https://xxxx@sentry.io/yyyy

# ── Infrastructure ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPLOAD_DIR=uploads
